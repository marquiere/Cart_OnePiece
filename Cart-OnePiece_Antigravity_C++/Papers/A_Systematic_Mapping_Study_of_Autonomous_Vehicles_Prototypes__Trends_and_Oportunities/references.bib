@article{ozguner2006,
   abstract = {Car safety systems are helping drivers to stay in their lanes, improving their night vision and are making driving decisions where millisecond response is needed. ABSTRACT | In this paper, we review technologies for autonomous ground vehicles and their present capabilities in research and in the automotive market. We outline technology requirements for enhanced functions and for infrastructure development. Since the recent Grand Challenge competition is a major force to advance technology in this field, we specifically refer to our experiences in developing a participating vehicle. We present a multisensor platform that has been proven in an off-road environment. It combines different sensing modalities that inherently yield uncertain information. Finite-state machines are formulated to generate rule-based autonomous behavior that enables fully autonomous off-road driving. Overall, the intent of the paper is to evaluate approaches and technologies used in the two Grand Challenges as they contribute to the needs of autonomous cars on the road.},
   author = {Member Ieee and Christoph Stiller and Senior Member IEEE and Keith Redmill},
   doi = {10.1109/JPROC.2007.888394},
   isbn = {2007.888394},
   keywords = {autonomous vehicles,cars,intelligent vehicles,safety,sensor fusion,| Autonomous systems},
   title = {Systems for Safety and Autonomous Behavior in Cars: The DARPA Grand Challenge Experience},
