@inproceedings{hirschmuller2005,
   abstract = {This paper considers the application of capturing urban terrain by an airborne pushbroom camera (e.g. High Resolution Stereo Camera). The resulting images as well as disparity ranges are expected to be huge. A slightly non-linear flight path and small orientation changes are anticipated, which results in curved epipolar lines. These images cannot be geometrically corrected for matching purposes such that epipolar lines are exactly straight and parallel to each other. The proposed novel processing solution explicitely calculates epipolar lines for reducing the disparity search range to a minimum. This is a necessary prerequisite for using an accurate, but memory intensive semi global stereo matching method that is based on pixelwise matching. It is shown that the proposed approach performs accurate matching of urban terrain and is efficient on huge images.},
   author = {Heiko Hirschmüller and Frank Scholten and Gerd Hirzinger},
   city = {Berlin, Heidelberg},
   editor = {Walter G Kropatsch and Robert Sablatnig and Allan Hanbury},
   isbn = {978-3-540-31942-9},
   journal = {Pattern Recognition},
   pages = {58-66},
   publisher = {Springer Berlin Heidelberg},
   title = {Stereo Vision Based Reconstruction of Huge Urban Areas from an Airborne Pushbroom Camera (HRSC)},
   year = {2005},
}
@article{Kant1986,
   abstract = {We present a novel approach to solving the trajectory plan ning problem (TPP) in time-varying environments. The es sence of our approach lies in a heuristic but natural decom position of TPP into two subproblems: (1) planning a path to avoid collision with static obstacles and (2) planning the velocity along the path to avoid collision with moving obsta cles. We call thefirst subproblem the path planning problem (PPP) and the second the velocity planning problem (VPP). Thus, our decomposition is summarized by the equation TPP => PPP + VPP. The symbol => indicates that the de composition holds under certain assumptions, e.g., when obstacles are moving independently of (i.e., not tracking ) the robot. Furthermore, we pose the VPP in path-time space, where time is explicitly represented as an extra dimension, and reduce it to a graph search in this space. In fact, VPP is transformed to a two-dimensional PPP in path-time space with some additional constraints. Algorithms are then pre sented to solve the VPP with different optimality criteria: minimum length in path-time space, and minimum time.},
   author = {Kamal Kant and Steven W Zucker},
   doi = {10.1177/027836498600500304},
   issn = {0278-3649},
   issue = {3},
   journal = {The International Journal of Robotics Research},
   month = {9},
   note = {doi: 10.1177/027836498600500304},
   pages = {72-89},
   publisher = {SAGE Publications Ltd STM},
   title = {Toward Efficient Trajectory Planning: The Path-Velocity Decomposition},
   volume = {5},
   url = {https://doi.org/10.1177/027836498600500304},
   year = {1986},
}
@misc{dickmanns1990,
   abstract = {Absfmcf-The ffilman filter approach to recursive state estimation exploiting dynamical models for the motion of massive objects has been extended to image sequence processing. This allows to confine image processing to the last frame of the sequence only and to derive a direct spatial interpretation including spatial velocity components by smoothing integrations of prediction errors. Results are presented for road vehicle guidance at bigh speeds induding obstacle detection and monoc-ular relative spatisl State estimation. The cnmponding data processing architectwe is discus&, the system bas been implemented on a M M D parallel processing system. Speeds up to 100 km/h have been deman-strated. INTRODUCIIOV HE CONTINUOUS DEVELOPMENT of action is a T prerequisite for understanding this action in real time. A slide show temporally compressed to video rate by displaying 25 or 30 frames a second wit1 not be understood by a human observer. This shows, that dynamic scene analysis is more than fast static image processing. Both spatial and temporal continuity conditions govern the understanding of processes occurring in the real world. Video rate has been defined in such a way that the human observer (in general) does not notice jumps in motion displayed even though they are there. The human visual system requires two events to be about 30 ms apart to clearly discriminate their temporal sequence [16]. On the other side, motion displayed at 10 Hz looks smooth, if the displacements are not too large. These facts have led us to specify the desirable image evaluation rate at 10 to 30 Hz, if dynamical behavior in the range of humans is required. The image processing rate should probably best be full video half-frame rate of 50 or 60 Hz in order to reduce the search space for features from one frame to the next. This means, that image sequence processing and image sequence understanding may run with different cycle times by a factor of 2 to 6. In natural science, temporal continuity conditions are described by differential equations. Reference I1 11 exploited these socalled dynamical models for achieving recursive least squares state estimation, given noise cor-IEEE Log Number 9037592. rupted measurements, yielding best estimates of the entire set of state variables even though not all variables had been measured. This famous principle, originally developed for linear systems, has been extended to nonlinear ones. In out approach to machine vision, this method is extended further to encompass three-dimensional (3-D) shape descriptions and perspective projection as the basic transition from object state to measured features in the image sequence. The dynamical models as used in modern control theory contain both a state transition component (the temporal continuity) and a control component integrating the effects of control actuation. These features are essential for autonomous guidance of vehicles. Expectations can be built up yielding information for the vision process where to look for interesting features and when to switch from one set of features to another one. Active perception is considered essential from a temporal point of view too: Massive systems and the measurement process are subject to phase shifts (delays) that can be counteracted by lead signals, which in turn are most easily derivable from dynamical models. The method developed has been applied to four different problem areas with great success: 1) Balancing of an inverted pendulum on an electro cart [141; 2) Rendezvous and docking of a satellite model plant [19], [20]; 3) Simulated autonomous landing approach of a jet aircraft, with image processing hardware in the real-time loop [7]; and 4) High speed road vehicIe guidance [21]. A survey on the general method and the four applications is given in [41. The last application area will be discussed in more detail in the sequel of this paper. Ego-state estimation both relative to the road and to another object will be discussed using the same basic "4-D method." Even the estimation of road curvature parameters can be done recursively using the same approach. It is numerically efficient and atlows to achieve the cycle times requested with about a dozen microprocessors of today's standard. THE INTEGRATED SPATIOTEMPORAL APPROACH For a reliable description of mechanical processes in our everyday environment science ha5 found the framework of three-dimensional space and time to be well 0018-9472/90/11OO-1273$01.OO 01990 IEEE Authorized licensed use limited to: PUC MG. Downloaded on March 22,2024 at 01:01:12 UTC from IEEE Xplore. Restrictions apply.},
   author = {E D Dickmanns and B Mysliwetz and T Christians},
   issue = {6},
   pages = {1273},
   title = {An Integrated Spatio-Temporal Approach to Automatic Visual Guidance of Autonomous Vehicles The authors are with the Fakultat fGr Luft-und Raumfahrttechnik},
   volume = {20},
}
@article{Montemerlo2008,
   abstract = {This article presents the architecture of Junior, a robotic vehicle capable of navigating urban environments autonomously. In doing so, the vehicle is able to select its own routes, perceive and interact with other traffic, and execute various urban driving skills including lane changes, U-turns, parking, and merging into moving traffic. The vehicle successfully finished and won second place in the DARPA Urban Challenge, a robot competition organized by the U.S. Government. © 2008 Wiley Periodicals, Inc.},
   author = {Michael Montemerlo and Jan Becker and Suhrid Shat and Hendrik Dahlkamp and Dmitri Dolgov and Scott Ettinger and Dirk Haehnel and Tim Hilden and Gabe Hoffmann and Burkhard Huhnke and Doug Johnston and Stefan Klumpp and Dirk Langer and Anthony Levandowski and Jesse Levinson and Julien Marcil and David Orenstein and Johannes Paefgen and Isaac Penny and Anna Petrovskaya and Mike Pflueger and Ganymed Stanek and David Stavens and Antone Vogt and Sebastian Thrun},
   doi = {10.1002/rob.20258},
   issn = {15564959},
   issue = {9},
   journal = {Journal of Field Robotics},
   month = {9},
   pages = {569-597},
   title = {Junior: The Stanford entry in the urban challenge},
   volume = {25},
   year = {2008},
}
@misc{McCall2006,
   abstract = {Driver-assistance systems that monitor driver intent, warn drivers of lane departures, or assist in vehicle guidance are all being actively considered. It is therefore important to take a critical look at key aspects of these systems, one of which is lane-position tracking. It is for these driver-assistance objectives that motivate the development of the novel "video-based lane estimation and tracking" (VioLET) system. The system is designed using steerable filters for robust and accurate lane-marking detection. Steerable filters provide an efficient method for detecting circular-reflector markings, solid-line markings, and segmented-line markings under varying lighting and road conditions. They help in providing robustness to complex shadowing, lighting changes from overpasses and tunnels, and road-surface variations. They are efficient for lane-marking extraction because by computing only three separable convolutions, we can extract a wide variety of lane markings. Curvature detection is made more robust by incorporating both visual cues (lane markings and lane texture) and vehicle-state information. The experiment design and evaluation of the VioLET system is shown using multiple quantitative metrics over a wide variety of test conditions on a large test path using a unique instrumented vehicle. A justification for the choice of metrics based on a previous study with human-factors applications as well as extensive ground-truth testing from different times of day, road conditions, weather, and driving scenarios is also presented. In order to design the VioLET system, an up-to-date and comprehensive analysis of the current state of the art in lane-detection research was first performed. In doing so, a comparison of a wide variety of methods, pointing out the similarities and differences between methods as well as when and where various methods are most useful, is presented. © 2006 IEEE.},
   author = {Joel C. McCall and Mohan M. Trivedi},
   doi = {10.1109/TITS.2006.869595},
   issn = {15249050},
   issue = {1},
   journal = {IEEE Transactions on Intelligent Transportation Systems},
   keywords = {Active safety systems,Intelligent vehicles,Lane detection,Lane-departure warning,Machine vision,Performance metrics},
   month = {3},
   pages = {20-37},
   title = {Video-based lane estimation and tracking for driver assistance: Survey, system, and evaluation},
   volume = {7},
   year = {2006},
}
@article{Bertozzi2013,
   abstract = {In recent years the interest in autonomous vehicles has incrementally increased. After the DARPA Challenges new fields of application as agricultural, construction, mining, and also nautical are continuously opening up. In this paper a huge test is presented, the first of this kind in the history of vehicular robotics. A trip from Italy to China with four electric autonomous vehicles will be described focusing on all aspects of the challenge, from the managing issues to the most technical ones. A vehicle-following application (or virtual towing) is the system under test for a three consecutive months and 13,000 km long unique experience.},
   author = {M. Bertozzi and A. Broggi and A. Coati and R. I. Fedriga},
   doi = {10.1109/mits.2012.2225651},
