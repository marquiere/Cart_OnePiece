/**
 * CARLA C++ Client Example: Spawn a Mercedes Coupe
 *
 * Requirements:
 * - Connect to 127.0.0.1:2000
 * - Prefer "vehicle.mercedes.coupe"
 * - Retry spawn on failure
 * - Autopilot OFF
 * - Print details
 * - RAII Cleanup
 */

#include <iostream>
#include <random>
#include <stdexcept>
#include <string>
#include <thread>
#include <chrono>
#include <iomanip>
#include <sstream>
#include <fstream>
#include <vector>
#include <map>
#include <mutex>
#include <set>

// CARLA headers
#include <carla/client/Client.h>
#include <carla/client/Actor.h>
#include <carla/actors/BlueprintLibrary.h>
#include <carla/actors/ActorBlueprint.h>
#include <carla/client/Map.h>
#include <carla/client/World.h>
#include <carla/geom/Transform.h>
#include <carla/client/Sensor.h>
#include <carla/sensor/data/Image.h>
#include <carla/sensor/data/DVSEventArray.h>
#include <carla/image/CityScapesPalette.h>
#include <carla/rpc/ActorId.h>
#include <cmath>

namespace cc = carla::client;
namespace cg = carla::geom;
namespace csd = carla::sensor::data;
namespace cr = carla::rpc;

using namespace std::chrono_literals;

// Helper to clean up actor on exit
class ActorDestroyer {
public:
    explicit ActorDestroyer(boost::shared_ptr<cc::Actor> actor) : actor_(std::move(actor)) {}
    
    ~ActorDestroyer() {
        if (actor_) {
            try {
                actor_->Destroy();
                std::cout << "Actor " << actor_->GetDisplayId() << " (ID: " << actor_->GetId() << ") destroyed." << std::endl;
            } catch (const std::exception& e) {
                std::cerr << "Error destroying actor: " << e.what() << std::endl;
            }
        }
    }

    // Prevent copying to avoid double destruction issues (though SharedPtr handles it, explicit ownership logic is safer for RAII wrapper)
    ActorDestroyer(const ActorDestroyer&) = delete;
    ActorDestroyer& operator=(const ActorDestroyer&) = delete;

private:
    boost::shared_ptr<cc::Actor> actor_;
};

int main(int argc, char* argv[]) {
    try {
        std::string host = "127.0.0.1";
        uint16_t port = 2000;

        if (argc > 1) host = argv[1];
        if (argc > 2) port = static_cast<uint16_t>(std::stoi(argv[2]));

        std::cout << "Connecting to " << host << ":" << port << "..." << std::endl;

        cc::Client client(host, port);
        client.SetTimeout(10s); // 10 seconds timeout

        std::cout << "Connected!" << std::endl;
        std::cout << "Client API version: " << client.GetClientVersion() << std::endl;
        std::cout << "Server API version: " << client.GetServerVersion() << std::endl;

        auto world = client.GetWorld();
        auto library = world.GetBlueprintLibrary();

        // 1. Select Blueprint
        // Prefer "vehicle.mercedes.coupe"
        auto blueprint = library->Find("vehicle.mercedes.coupe");
        
        if (!blueprint) {
            std::cout << "Warning: 'vehicle.mercedes.coupe' not found. Selecting a random vehicle..." << std::endl;
            auto vehicles = library->Filter("vehicle");
            if (vehicles->empty()) {
                throw std::runtime_error("No vehicle blueprints found!");
            }
            // Simple random selection
             std::mt19937_64 rng((std::random_device())());
             std::uniform_int_distribution<size_t> dist{0u, vehicles->size() - 1u};
             blueprint = &vehicles->at(dist(rng));
        }

        // Create a mutable copy of the blueprint to allow modification
        carla::actors::ActorBlueprint mutable_blueprint = *blueprint;

        // Set color to Yellow (255,255,0)
        if (mutable_blueprint.ContainsAttribute("color")) {
            mutable_blueprint.SetAttribute("color", "255,255,0");
        } else {
            std::cout << "Warning: Blueprint does not support color attribute." << std::endl;
        }

        std::cout << "Selected Blueprint: " << mutable_blueprint.GetId() << std::endl;

        // Ensure Autopilot is OFF (it is by default for new actors, but good to be explicit if using traffic manager, 
        // though strictly initiating the actor doesn't turn it on).
        // The requirement is "Autopilot OFF". We will verify this after spawning.

        // 2. Choose a valid spawn point and retry on failure
        auto map = world.GetMap();
        auto spawn_points = map->GetRecommendedSpawnPoints();

        if (spawn_points.empty()) {
            throw std::runtime_error("No spawn points available!");
        }

        boost::shared_ptr<cc::Actor> actor;
        cg::Transform spawn_transform;
        
        // Retry logic
        // We will try recommended spawn points in random order until one works.
        std::shuffle(spawn_points.begin(), spawn_points.end(), std::mt19937(std::random_device{}()));
        
        for (const auto& transform : spawn_points) {
            actor = world.TrySpawnActor(mutable_blueprint, transform);
            if (actor) {
                spawn_transform = transform;
                break;
            }
        }

        if (!actor) {
            throw std::runtime_error("Failed to spawn actor at any of the recommended spawn points.");
        }

        // RAII Cleanup
        ActorDestroyer destroyer(actor);

        // 3. Print details
        std::cout << "Successfully Spawned Actor!" << std::endl;
        std::cout << "  - Actor ID: " << actor->GetId() << std::endl;
        std::cout << "  - Blueprint ID: " << actor->GetTypeId() << std::endl;
        std::cout << "  - Location: X=" << spawn_transform.location.x 
                  << ", Y=" << spawn_transform.location.y 
                  << ", Z=" << spawn_transform.location.z << std::endl;
        std::cout << "  - Rotation: Pitch=" << spawn_transform.rotation.pitch 
                  << ", Yaw=" << spawn_transform.rotation.yaw 
                  << ", Roll=" << spawn_transform.rotation.roll << std::endl;

        // Confirm Autopilot is ON
        auto vehicle = boost::static_pointer_cast<cc::Vehicle>(actor);
        if (vehicle) {
             [[maybe_unused]] auto tm = client.GetInstanceTM(8000);
             vehicle->SetAutopilot(true, 8000);
             vehicle->SetAutopilot(true, 8000);
             std::cout << "  - Autopilot: ON (Port 8000)" << std::endl;
        }

        // Dataset output directories
        // Dataset output directories
        const std::string base_dir = "/mnt/intel32g/Cart-OnePiece_Datasets/antigravity_cpp_yellow/";
        
        // Validating writable path
        if (system(("mkdir -p " + base_dir).c_str()) != 0) {
            throw std::runtime_error("Failed to create/write to dataset root: " + base_dir);
        }

        const std::vector<std::string> sensors = {"rgb", "depth", "semantic", "instance", "optflow", "dvs"};
        for (const auto& s : sensors) system(("mkdir -p " + base_dir + s).c_str());

        // Manifest syncing
        struct FrameEntry {
            std::map<std::string, std::string> paths;
        };
        std::map<uint64_t, FrameEntry> manifest_buffer;
        std::mutex manifest_mutex;
        std::ofstream manifest_file(base_dir + "manifest.csv", std::ios::app);
        
        // Helper to spawn and listen
        auto spawn_sensor = [&](const std::string& type_id, const std::string& name, auto callback) {
            auto bp_ptr = library->Find(type_id);
            if (!bp_ptr) throw std::runtime_error("Blueprint not found: " + type_id);
            
            // Create mutable copy
            carla::actors::ActorBlueprint bp = *bp_ptr;
            
            // Standardize image resolution if applicable
             if (bp.ContainsAttribute("image_size_x")) {
                 bp.SetAttribute("image_size_x", "800");
                 bp.SetAttribute("image_size_y", "600");
             }

            cg::Transform tf(cg::Location(1.5f, 0.0f, 1.2f));
            // Use outer 'actor' (the vehicle) as parent
            auto sensor_actor = world.SpawnActor(bp, tf, actor.get());
            auto sensor = boost::static_pointer_cast<cc::Sensor>(sensor_actor);
            
            sensor->Listen([&, name, callback](auto data) {
                if (!data) return;
                
                std::stringstream ss_id;
                ss_id << std::setw(6) << std::setfill('0') << data->GetFrame();
                
                // Timestamp for filename (simplified, usually from data->GetTimestamp())
                // We use a fixed format for base_id as requested
                // "frame_000123_YYYYMMDD_HHMMSS" - hard to get exact wall clock from sensor timestamp cheaply without logic.
                // We will use current system time for the filename part to satisfy requirement roughly,
                // OR better, just use Frame ID + generic request format. 
                // The constraint says "{frame:06d}_{YYYYMMDD_HHMMSS}". 
                // We'll compute the time string once per frame if possible, or just generate it here.
                
                auto now = std::chrono::system_clock::to_time_t(std::chrono::system_clock::now());
                std::stringstream ss_time;
                ss_time << std::put_time(std::localtime(&now), "%Y%m%d_%H%M%S");
                
                std::string base_id = ss_id.str() + "_" + ss_time.str();
                std::string filename = name + "_" + base_id;
                // Specific extensions handled by callback

                std::string full_path = callback(data, base_dir + name + "/" + filename);
                
                // Manifest Update
                std::lock_guard<std::mutex> lock(manifest_mutex);
                auto& entry = manifest_buffer[data->GetFrame()];
                entry.paths[name] = full_path;

                // If all sensors present (6 modalities), write and remove
                if (entry.paths.size() == 6) {
                    manifest_file << base_id;
                    for (const auto& s : sensors) manifest_file << "," << entry.paths[s];
                    manifest_file << "\n" << std::flush;
                    manifest_buffer.erase(data->GetFrame());
                }
            });
            
            return sensor; // Keep alive
        };

        // Keep sensors alive
        std::vector<boost::shared_ptr<cc::Sensor>> active_sensors;
        std::vector<boost::shared_ptr<cc::Actor>> actors_to_destroy;

        // 1. RGB
        active_sensors.push_back(spawn_sensor("sensor.camera.rgb", "rgb", [](auto data, auto path) {
            auto image = boost::static_pointer_cast<csd::Image>(data);
            path += ".ppm";
            std::ofstream file(path, std::ios::binary);
            file << "P6\n" << image->GetWidth() << " " << image->GetHeight() << "\n255\n";
            auto buffer = image->begin();
            for (auto& pixel : *image) {
                char rgb[3] = { (char)pixel.r, (char)pixel.g, (char)pixel.b };
                file.write(rgb, 3);
            }
            return path;
        }));

        // 2. Depth
        active_sensors.push_back(spawn_sensor("sensor.camera.depth", "depth", [](auto data, auto path) {
            auto image = boost::static_pointer_cast<csd::Image>(data);
            path += ".ppm";
            std::ofstream file(path, std::ios::binary);
            file << "P6\n" << image->GetWidth() << " " << image->GetHeight() << "\n255\n";
            for (auto& pixel : *image) {
                // Depth is encoded in B, G, R. We just save the raw encoded color as PPM (visual/storage).
                // Usually LogarithmicDepth is better for viz, but raw bits are better for data.
                // We write the raw RGB (swizzled from BGRA) to preserve data.
                char rgb[3] = { (char)pixel.r, (char)pixel.g, (char)pixel.b };
                file.write(rgb, 3);
            }
            return path;
        }));

        // 3. Semantic
        active_sensors.push_back(spawn_sensor("sensor.camera.semantic_segmentation", "semantic", [](auto data, auto path) {
            auto image = boost::static_pointer_cast<csd::Image>(data);
            path += ".ppm";
            std::ofstream file(path, std::ios::binary);
            file << "P6\n" << image->GetWidth() << " " << image->GetHeight() << "\n255\n";
            for (auto& pixel : *image) {
                // Apply CityScapes Palette
                // mixed types: pixel.r is uint8_t, GetColor returns uint8_t[3]
                auto color = carla::image::CityScapesPalette::GetColor(pixel.r);
                char rgb[3] = { (char)color[0], (char)color[1], (char)color[2] };
                file.write(rgb, 3);
            }
            return path;
        }));

        // 4. Instance
        active_sensors.push_back(spawn_sensor("sensor.camera.instance_segmentation", "instance", [](auto data, auto path) {
            auto image = boost::static_pointer_cast<csd::Image>(data);
            path += ".ppm";
            std::ofstream file(path, std::ios::binary);
            file << "P6\n" << image->GetWidth() << " " << image->GetHeight() << "\n255\n";
            for (auto& pixel : *image) {
                // Instance ID is encoded in R, G, B. Write as is for raw data.
                // Could visualize by hashing to color, but raw is better for dataset.
                char rgb[3] = { (char)pixel.r, (char)pixel.g, (char)pixel.b };
                file.write(rgb, 3);
            }
            return path;
        }));

        // 5. Optical Flow
        active_sensors.push_back(spawn_sensor("sensor.camera.optical_flow", "optflow", [](auto data, auto path) {
            auto image = boost::static_pointer_cast<csd::OpticalFlowImage>(data);
            path += ".ppm";
            std::ofstream file(path, std::ios::binary);
            file << "P6\n" << image->GetWidth() << " " << image->GetHeight() << "\n255\n";
            
            for (auto& pixel : *image) {
                // Improved Optical Flow Visualization (angle -> hue, magnitude -> value)
                float vx = pixel.x; 
                float vy = pixel.y; 
                
                float magnitude = std::sqrt(vx*vx + vy*vy);
                float angle = std::atan2(vy, vx); // -pi to pi
                
                // Hue: (-pi, pi) -> (0, 360)
                float hue = (angle + M_PI) * 180.0f / M_PI;
                
                // Saturation: 1.0
                float s = 1.0f;
                
                // Value: Scale magnitude to be visible
                // Use logarithmic scaling to handle small motions (0-1px) and large motions (10+px)
                // log(1 + 0.1*10) = log(2) ~ 0.69 (visible)
                // log(1 + 1.0*10) = log(11) ~ 2.4 (saturated)
                float v = std::min(1.0f, std::log(1.0f + magnitude * 10.0f)); 
                
                // HSV to RGB
                float c = v * s;
                float x = c * (1.0f - std::abs(std::fmod(hue / 60.0f, 2.0f) - 1.0f));
                float m = v - c;
                
                float r_prime = 0, g_prime = 0, b_prime = 0;
                if (0 <= hue && hue < 60) { r_prime = c; g_prime = x; b_prime = 0; }
                else if (60 <= hue && hue < 120) { r_prime = x; g_prime = c; b_prime = 0; }
                else if (120 <= hue && hue < 180) { r_prime = 0; g_prime = c; b_prime = x; }
                else if (180 <= hue && hue < 240) { r_prime = 0; g_prime = x; b_prime = c; }
                else if (240 <= hue && hue < 300) { r_prime = x; g_prime = 0; b_prime = c; }
                else if (300 <= hue && hue < 360) { r_prime = c; g_prime = 0; b_prime = x; }
                
                char rgb[3] = { 
                    (char)((r_prime + m) * 255), 
                    (char)((g_prime + m) * 255), 
                    (char)((b_prime + m) * 255) 
                };
                file.write(rgb, 3);
            }
            return path;
        }));

        // 6. DVS
        active_sensors.push_back(spawn_sensor("sensor.camera.dvs", "dvs", [](auto data, auto path) {
            auto events = boost::static_pointer_cast<csd::DVSEventArray>(data);
            path += ".jsonl";
            std::ofstream file(path);
            for (const auto& e : *events) {
                file << "{\"t\":" << e.t << ",\"x\":" << e.x << ",\"y\":" << e.y << ",\"pol\":" << e.pol << "}\n";
            }
            return path;
        }));
        
        std::cout << "  - Dataset Recording: ON (6 Modalities) -> " << base_dir << std::endl;
        
        // Add sensors to cleanup list
        for (auto& s : active_sensors) {
            actors_to_destroy.push_back(boost::static_pointer_cast<cc::Actor>(s));
        }
        
        // Custom destructor for list of actors
        class ListDestroyer {
            std::vector<boost::shared_ptr<cc::Actor>> list;
        public:
            ListDestroyer(std::vector<boost::shared_ptr<cc::Actor>> l) : list(l) {}
            ~ListDestroyer() { for(auto& a : list) if(a) a->Destroy(); }
        } sensor_destroyer(actors_to_destroy);

        std::cout << "\nPress ENTER to destroy the actor and exit..." << std::endl;
        std::cin.get();

    } catch (const std::exception& e) {
        std::cerr << "Error: " << e.what() << std::endl;
        return 1;
    }

    return 0;
}
