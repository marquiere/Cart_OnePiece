	@$(MKDIR_P) fortran90
	@: > fortran90/$(am__dirstamp)
fortran90/$(DEPDIR)/$(am__dirstamp):
	@$(MKDIR_P) fortran90/$(DEPDIR)
	@: > fortran90/$(DEPDIR)/$(am__dirstamp)
